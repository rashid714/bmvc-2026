{
  "epochs": 5,
  "batch_size": 32,
  "eval_batch_size": 64,
  "learning_rate": 2e-5,
  "weight_decay": 0.01,
  "warmup_fraction": 0.1,
  "max_rows_per_source": 40000,
  "seeds": [41, 42, 43],
  "hidden_dim": 1024,
  "num_emotion_classes": 11,
  "num_intention_classes": 20,
  "num_action_classes": 15,
  "dropout_rate": 0.2,
  "fp16": true,
  "grad_accum_steps": 1,
  "num_workers": 4,
  "pin_memory": true,
  "use_calibration": true,
  "use_multimodal": true,
  "dataset_profile": "ultra_30gb",
  "hf_cache_dir": ".hf_cache/datasets",
  "cloud_sources": ["goemotions", "dailydialog", "tweet_eval", "mine", "emoticon", "raza", "coco", "voxceleb"],
  "llm_downloads": ["roberta-large", "distilroberta-base"],
  "emotion_weight": 1.0,
  "intention_weight": 1.2,
  "action_weight": 1.0
}
