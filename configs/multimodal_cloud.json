{
  "epochs": 4,
  "batch_size": 32,
  "eval_batch_size": 64,
  "learning_rate": 2e-5,
  "weight_decay": 0.01,
  "warmup_fraction": 0.1,
  "max_rows_per_source": 5000,
  "seeds": [41, 42, 43],
  "text_backbone": "distilroberta-base",
  "hidden_dim": 768,
  "num_emotion_classes": 11,
  "num_intention_classes": 20,
  "num_action_classes": 15,
  "dropout_rate": 0.2,
  "fp16": true,
  "grad_accum_steps": 1,
  "num_workers": 4,
  "pin_memory": true,
  "use_calibration": true,
  "use_multimodal": true,
  "hf_cache_dir": "data/hf_datasets",
  "model_cache_dir": "models/hf_models",
  "hf_hub_cache_dir": "models/hf_hub",
  "cloud_sources": ["goemotions", "dailydialog", "tweet_eval", "mine", "emoticon", "raza", "coco"],
  "emotion_weight": 1.0,
  "intention_weight": 1.2,
  "action_weight": 1.0
}
